{
  "name": "adzuna-sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for the Adzuna API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "openapi-typescript adzuna_swagger.json -o src/schema.ts",
    "test": "bun test test/client.test.ts test/constants.test.ts",
    "test:integration": "bun test test/integration.test.ts",
    "test:types": "tsc --noEmit -p tsconfig.tests.json",
    "test:all": "bun run test && bun run test:types && bun run test:integration",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run generate && bun run typecheck && bun run test && bun run test:types && bun run build"
  },
  "keywords": [
    "adzuna",
    "jobs",
    "sdk",
    "typescript"
  ],
  "author": "Josh Hubbard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhubbardsf/adzuna-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/jhubbardsf/adzuna-sdk/issues"
  },
  "homepage": "https://github.com/jhubbardsf/adzuna-sdk#readme",
  "dependencies": {
    "ky": "^1.7.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "expect-type": "^1.3.0",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
